# GlitchGoal environment configuration. Copy to .env and fill in.
# Get these from your Supabase project settings (API).

# --- Client (Vite) — safe to expose, gated by Row Level Security ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Signaling server — SECRET, never ship to the browser ---
# Bypasses RLS to record matches + update MMR authoritatively.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Signaling server port (optional, default 8080)
PORT=8080
